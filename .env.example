ANTHROPIC_API_KEY=your_claude_key
GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-2.5-flash-lite
CLAUDE_MODEL=claude-haiku-4-5
EMAIL_TO_ALIAS=your_email_alias@example.com

# Frontend dashboard link used in generated emails
PHASE7_APP_LINK=https://groww-review-insight-analyser.vercel.app

# Email transport (use brevo for Render free tier – HTTPS API, no SMTP; personal mail OK)
EMAIL_PROVIDER=brevo
EMAIL_FROM_NAME=Groww Pulse Bot
EMAIL_FROM_ADDRESS=your_personal@gmail.com

# Brevo (recommended: HTTPS API, works on Render free tier; sender = verified personal mail)
BREVO_API_KEY=your_brevo_api_key
BREVO_FROM_EMAIL=your_personal@gmail.com

# Resend (requires verified domain)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=reports@yourdomain.com

# SMTP (optional; often blocked on Render free tier)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your_sender@gmail.com
SMTP_PASSWORD=your_app_password

WEEKLY_SCHEDULED_RECIPIENT=weekly_owner@example.com
WEEKLY_SCHEDULE_DAY=MON
WEEKLY_SCHEDULE_TIME=10:00

WEEKLY_WEEKS_FROM=1
WEEKLY_WEEKS_TO=15

# Vercel frontend -> backend pipeline webhook
PIPELINE_TRIGGER_URL=
PIPELINE_TRIGGER_TOKEN=
